---
import { NAV_MENU } from "../consts";
import HeaderLink from "./HeaderLink.astro";
import { ChevronRight } from "@lucide/astro";
import Logo from "./Logo.astro";
---

<div class="drawer-side">
  <label for="my-drawer-2" aria-label="close sidebar" class="drawer-overlay"
  ><span class="sr-only">Open menu</span>
</label>
  <div class="menu bg-base-200 min-h-full w-80 p-4">
    <Logo />
    <ul class="mt-4">
      {
        NAV_MENU.map((item) => (
          <li>
            <HeaderLink item={item} />
          </li>
        ))
      }
    </ul>
    <div class="flex flex-col gap-2 items-center w-full mt-auto">
      <a
        href="/login"
        class="btn btn-sm w-full rounded-md bg-white text-main font-light"
      >
        Login
        <ChevronRight size="14" />
      </a>
      <a
        href="/signup"
        class="btn btn-sm w-full rounded-md bg-main border-main text-white font-light"
      >
        Sign Up
        <ChevronRight size="14" />
      </a>
    </div>
  </div>
</div>
