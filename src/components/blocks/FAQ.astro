---
import { ChevronRight } from "@lucide/astro";

interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  heading: string;
  body: string;
  ctaLabel: string;
  ctaHref: string;
  faqs: FaqItem[];
}

const { heading, body, ctaLabel, ctaHref, faqs } = Astro.props;

// FAQ Schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};
---

<!-- FAQ JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<section class="section section-faq">
  <div class="container">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
      <div>
        <h2 class="h3 dark:text-black">{heading}</h2>

        <p class="text-base text-custom-grey-100 mb-8">
          {body}
        </p>

        <a
          href={ctaHref}
          class="btn btn-lg w-full sm:w-auto rounded-md bg-main hover:bg-blue-600 border-main text-white font-light"
        >
          {ctaLabel}
          <ChevronRight size="14" />
        </a>
      </div>

      <div class="grid gap-3">
        {
          faqs.map((faq, index) => (
            <div class="collapse collapse-arrow bg-base-100 border border-base-300 dark:bg-white dark:text-black dark:border-white">
              <input
                type="radio"
                name="faq-accordion"
                checked={index === 0}
                aria-hidden="true"
                tabindex="-1"
              />

              <div class="collapse-title font-semibold">{faq.question}</div>

              <div class="collapse-content text-sm">{faq.answer}</div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
