---
type BlockData = Record<string, unknown>;

interface Props {
  blocks?: BlockData[];
}

const modules = import.meta.glob<{ default: unknown }>(
  "/src/components/blocks/**/*.astro",
  { eager: true },
);

function keyFor(path: string): string {
  const name = path.split("/").pop()!.replace(/\.astro$/, "");
  if (/^[A-Z]+$/.test(name)) return name;
  return name.charAt(0).toLowerCase() + name.slice(1);
}

const BLOCK_COMPONENTS: Record<string, unknown> = {};
for (const [path, mod] of Object.entries(modules)) {
  if (path.endsWith("/Blocks.astro")) continue;
  BLOCK_COMPONENTS[keyFor(path)] = mod.default;
}

const { blocks = [] } = Astro.props;
---

{
  blocks.map((block) => {
    const Component = BLOCK_COMPONENTS[block._template as string] as any;
    return Component ? <Component {...block} /> : null;
  })
}
