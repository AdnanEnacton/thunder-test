                </li>
                <li class="grid grid-cols-[16px_1fr] items-center gap-1">
                  <CircleCheck size={16} />Email Support
                </li>
              </ul>
              <a
                href="#"
                class="btn btn-outline w-full rounded-md font-normal border-main text-main hover:bg-main hover:text-white"
                >Starts 14 days free trial</a
              >
            </article>

            <article
              class="bg-custom-blue-300 p-6 rounded-xl text-white ;lg:scale-110 w-full grid md:grid-cols-3 lg:grid-cols-1 items-center"
