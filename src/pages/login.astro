---
import Layout from "../layouts/Base.astro";
import LoginForm from "../components/forms/LoginForm.astro";
---

<Layout>
  <section class="grid grid-cols-1 lg:grid-cols-2 items-stretch min-h-screen">
    <div class="p-4 md:p-20">
      <div class="text-center">
        <a href="/">
          <img
            src="/img/logo-icon.svg"
            alt=""
            class="mx-auto mb-4"
            width="34"
            height="34"
          /></a
        >

        <h2 class="h3 my-2">Welcome back to Zeepay</h2>
        <p class="text-custom-grey-100">
          Enter your password and username to continue
        </p>
      </div>
      <div class="max-w-lg mx-auto mt-10">
        <LoginForm />

        <div class="divider my-6 text-custom-grey-100">or login with</div>
        <div class="grid grid-cols-2 gap-4">
          <button class="btn btn-outline border-black/20">
            <svg class="icon" width="16" height="16">
              <use xlink:href="#ic-google"></use>
            </svg>
            Google</button
          >

          <button class="btn btn-outline border-black/20">
            <svg class="icon" width="16" height="16">
              <use xlink:href="#ic-apple"></use>
            </svg>
            Apple</button
          >
        </div>
        <div class="mt-4 text-center text-custom-grey-100">
          Don’t have an account? <a
            href="/signup"
            class="text-black font-semibold hover:underline">Sign Up</a
          >
        </div>
      </div>
    </div>
    <div
      class="bg-custom-blue-300 text-white text-center grid bg-[url(/img/bg/bg3.svg)] bg-no-repeat bg-cover"
    >
      <div class="max-w-2xl mx-auto p-6 md:p-20">
        <h1 class="h2">
          Early pay, Automatic savings, Transform your money habits
        </h1>
        <p class="text-base md:text-lg text-custom-grey-100">
          Support small businesses with simple invoicing, powerful integrations,
          and cash flow management tools.
        </p>
      </div>

      <img
        src="/img/auth/img1.png"
        alt=""
        width="518"
        height="572"
        fetchpriority="high"
        class="w-auto h-auto mx-auto mt-auto"
      />
    </div>
  </section>

